{
  "name": "@coalescefi/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for CoalesceFi lending protocol",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "!dist/**/*.js.map",
    "!dist/**/*.d.ts.map",
    "src/**/*.ts",
    "!src/**/*.js",
    "!src/**/*.js.map",
    "!src/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@solana/addresses": "^2.0.0",
    "@solana/codecs": "^2.0.0",
    "@solana/errors": "^2.0.0",
    "@solana/instructions": "^2.0.0",
    "@solana/keys": "^2.0.0",
    "@solana/rpc": "^2.0.0",
    "@solana/rpc-api": "^2.0.0",
    "@solana/transactions": "^2.0.0",
    "@solana/compat": "^2.0.0",
    "@solana/web3.js": "^1.91.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "vitest": "^1.3.0"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.91.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/saguarocrypto/coalesce-sdk.git",
    "directory": "ts"
  },
  "license": "Apache-2.0",
  "keywords": [
    "solana",
    "defi",
    "lending",
    "sdk",
    "coalescefi"
  ]
}
